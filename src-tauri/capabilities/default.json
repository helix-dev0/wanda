{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "fs:allow-read-text-file",
    "fs:allow-watch",
    "fs:allow-unwatch",
    "dialog:allow-open",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "C:/**" },
        { "path": "D:/**" },
        { "path": "E:/**" },
        { "path": "F:/**" },
        { "path": "G:/**" },
        { "path": "H:/**" }
      ]
    }
  ]
}
